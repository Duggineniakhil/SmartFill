{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "lib": ["ES2023", "DOM"],
    "ignoreDeprecations": "5.0",
    "outDir": ".",
    "rootDir": ".",
    "strict": false,
    "noImplicitAny": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "moduleResolution": "node",
    "isolatedModules": true,
    "skipLibCheck": true,
    "allowJs": true,
    "checkJs": false,
    "declaration": false,
    "sourceMap": true,
    "esModuleInterop": true
  },
  "include": ["content/**/*.ts", "content/**/*.d.ts"],
  "exclude": ["node_modules", "dist"]
}
